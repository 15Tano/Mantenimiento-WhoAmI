          ),
          boxShadow: const [
            BoxShadow(
              blurRadius: 6,
              offset: Offset(0, 2),
              color: Color(0x22000000),
            ),
          ],
        ),
        child: Row(
          children: [
            const Icon(Icons.health_and_safety, size: 22),
            const SizedBox(width: 10),
            Expanded(
              child: Text(
                text,
